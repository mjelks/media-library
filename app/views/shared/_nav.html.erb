 <div data-controller="modal">
  <!-- Menu Section -->
  <nav class="bg-gray-800 text-white py-3" data-controller="nav">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between">

        <!-- Desktop nav links -->
        <div class="hidden md:flex space-x-6 items-center">
          <%= link_to "Now Playing", now_playing_path, class: "hover:text-blue-400" %>
          <%= link_to "Record Collection", record_collection_path, class: "hover:text-blue-400" %>
          <%= link_to "CD Collection", cd_collection_path, class: "hover:text-blue-400" %>
          <% unless auditor? %>
            <%= link_to "Wishlist", wishlist_index_path, class: "hover:text-blue-400" %>
            <%= link_to "Search Discogs", discogs_path, class: "hover:text-blue-400" %>

            <!-- Config dropdown -->
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle" class="hover:text-blue-400 flex items-center gap-1">
                Config
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute left-0 mt-2 bg-gray-800 rounded shadow-lg z-50 min-w-max">
                <%= link_to "Releases", releases_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400 border-b border-[#eee]" %>
                <%= link_to "Album/CD Locations", locations_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400 border-b border-[#eee]" %>
                <%= link_to "LP Cartridges", lp_cartridges_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400 border-b border-[#eee]" %>
                <%= link_to "Media Items", media_items_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400 border-b border-[#eee]" %>
                <%= link_to "Media Types", media_types_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400 border-b border-[#eee]" %>
                <%= link_to "Users", users_path, class: "block px-4 py-2 hover:bg-gray-700 hover:text-blue-400" %>
              </div>
            </div>
          <% end %>

          <% if authenticated? %>
            <%= button_to 'Sign out', session_path, method: :delete %>
          <% else %>
            <button data-action="modal#show"
                  class="hover:text-blue-400 bg-transparent border-none cursor-pointer">Sign in</button>
          <% end %>
        </div>

        <!-- Mobile top bar: hamburger + Now Playing + sign in/out -->
        <div class="flex md:hidden items-center space-x-4">
          <button data-action="click->nav#toggleMenu" class="p-2 rounded hover:bg-gray-700 focus:outline-none" aria-label="Toggle menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <%= link_to "Now Playing", now_playing_path, class: "hover:text-blue-400" %>
          <% if authenticated? %>
            <%= button_to 'Sign out', session_path, method: :delete %>
          <% else %>
            <button data-action="modal#show" class="hover:text-blue-400 bg-transparent border-none cursor-pointer">Sign in</button>
          <% end %>
        </div>
      </div>

      <!-- Mobile menu (hidden by default) -->
      <div data-nav-target="menu" class="hidden flex-col mt-3 space-y-2 pb-2 md:hidden">
        <%= link_to "Record Collection", record_collection_path, class: "block hover:text-blue-400" %>
        <%= link_to "CD Collection", cd_collection_path, class: "block hover:text-blue-400" %>
        <% unless auditor? %>
          <%= link_to "Wishlist", wishlist_index_path, class: "block hover:text-blue-400" %>
          <%= link_to "Search Discogs", discogs_path, class: "block hover:text-blue-400" %>

          <!-- Config sub-section (mobile) -->
          <div class="border-t border-gray-600 pt-2">
            <span class="text-gray-400 text-sm uppercase tracking-wide">Config</span>
            <div class="mt-1 flex flex-col space-y-1 pl-3">
              <%= link_to "Releases", releases_path, class: "block hover:text-blue-400" %>
              <%= link_to "Album/CD Locations", locations_path, class: "block hover:text-blue-400" %>
              <%= link_to "LP Cartridges", lp_cartridges_path, class: "block hover:text-blue-400" %>
              <%= link_to "Media Items", media_items_path, class: "block hover:text-blue-400" %>
              <%= link_to "Media Types", media_types_path, class: "block hover:text-blue-400" %>
              <%= link_to "Users", users_path, class: "block hover:text-blue-400" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </nav>

  <% content_for :modals do %>
    <%= render partial: 'shared/auth_modal' %>
  <% end %>
</div>
