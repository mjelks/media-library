<%= form_with(model: site_setting, url: site_setting_path, method: :patch, class: "contents") do |form| %>
  <% if site_setting.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(site_setting.errors.count, "error") %> prohibited these settings from being saved:</h2>
      <ul class="list-disc ml-6">
        <% site_setting.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow border border-gray-100 p-5 mb-4 space-y-4">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :subhead, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :subhead, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :background_image, "Background Image", class: "block text-sm font-medium text-gray-700" %>
      <%= form.file_field :background_image, accept: "image/*", class: "mt-1 block w-full" %>
      <% if site_setting.background_image.attached? %>
        <div class="mt-2">
          <%= image_tag site_setting.background_image.variant(resize_to_limit: [ 300, 150 ]), class: "rounded shadow" %>
        </div>
      <% end %>
      <p class="text-xs text-gray-400 mt-1">Leave blank to keep the current image. Uploading replaces it.</p>
    </div>
  </div>

  <div class="flex gap-3">
    <%= form.submit "Save Settings", class: "rounded-md px-3.5 py-2.5 themed-btn-primary font-medium cursor-pointer" %>
    <%= link_to "Cancel", site_setting_path, class: "rounded-md px-3.5 py-2.5 themed-btn-secondary font-medium" %>
  </div>
<% end %>
