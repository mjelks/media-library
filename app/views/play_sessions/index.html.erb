<% content_for :title, "#{@cartridge.name} Play History" %>

<div class="p-4 w-full max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-bold text-4xl">Play History</h1>
      <p class="themed-page-subtitle mt-1">
        <%= @cartridge.name %> &middot; installed <%= @cartridge.installed_at.strftime("%b %-d, %Y") %>
      </p>
    </div>
    <%= link_to "Back to Now Playing", now_playing_path, class: "rounded-md px-3.5 py-2.5 themed-btn-secondary font-medium" %>
  </div>

  <%= render "table",
      items_with_played_at: @media_items.map { |item| [ item, item.last_played ] },
      total_primary: duration_formatter(@total_seconds),
      total_secondary: "#{quarter_hours(@total_seconds)} hrs",
      empty_message: "No albums played on this cartridge yet." %>
</div>
