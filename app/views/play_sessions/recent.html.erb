<% content_for :title, "#{@heading} Play History" %>

<div class="p-4 w-full max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-bold text-4xl">Play History</h1>
      <p class="themed-page-subtitle mt-1"><%= @heading %></p>
    </div>
    <div class="flex items-center gap-3">
      <% if @days.nil? %>
        <%= play_history_view_toggle(active: :list) %>
      <% end %>
      <%= link_to "Back to Now Playing", now_playing_path, class: "rounded-md px-3.5 py-2.5 themed-btn-secondary font-medium" %>
    </div>
  </div>

  <%= render "table",
      items_with_played_at: @play_sessions.map { |ps| [ ps.media_item, ps.start_time ] },
      total_primary: @days.nil? ? duration_hms(@total_seconds) : duration_formatter(@total_seconds),
      total_secondary: @days.nil? ? duration_formatter(@total_seconds) : nil,
      empty_message: "No albums played in this window yet." %>
</div>
