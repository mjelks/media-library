<% content_for :title, "Play History — #{@month.strftime('%B %Y')}" %>

<div class="p-4 w-full max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-bold text-4xl">Play History</h1>
      <p class="themed-page-subtitle mt-1"><%= @month.strftime("%B %Y") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= play_history_view_toggle(active: :list, month: @month) %>
      <%= link_to "Back to Lifetime", play_sessions_path, class: "rounded-md px-3.5 py-2.5 themed-btn-secondary font-medium" %>
    </div>
  </div>

  <%= render "table",
      items_with_played_at: @play_sessions.map { |ps| [ ps.media_item, ps.start_time ] },
      total_primary: duration_formatter(@total_seconds),
      total_secondary: nil,
      empty_message: "No albums played in #{@month.strftime('%B %Y')}." %>
</div>
