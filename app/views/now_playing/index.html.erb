<% content_for :title, "Now Playing" %>

<div class="p-4 w-full max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-bold text-4xl">Now Playing</h1>
      <% if is_admin? %>
      <p class="themed-page-subtitle mt-1">Search your collection and track what you're listening to</p>
      <% end %>
    </div>
  </div>

  <!-- Search with Autocomplete -->
  <% if is_admin? %>
  <div class="mb-8" data-controller="now-playing-search media-type-toggle"
       data-now-playing-search-url-value="<%= now_playing_search_path %>"
       data-now-playing-search-random-url-value="<%= now_playing_random_path %>"
       data-now-playing-search-vinyl-description-value="<%= PickRandomConfig.current('Vinyl').description %>"
       data-now-playing-search-cd-description-value="<%= PickRandomConfig.current('CD').description %>"
       data-media-type-toggle-current-value="<%= @media_type %>">
    <div class="relative flex gap-2">
      <input type="text"
             data-now-playing-search-target="input"
             data-action="input->now-playing-search#search keydown->now-playing-search#handleKeydown"
             placeholder="Search by artist or album title..."
             autocomplete="off"
             class="flex-1 px-4 py-3 text-lg border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      <!-- Media Type Selector -->
      <div class="flex rounded-lg overflow-hidden border border-gray-300">
        <button type="button"
                data-media-type-toggle-target="button"
                data-now-playing-search-target="mediaTypeButton"
                data-media-type="Vinyl"
                data-action="click->media-type-toggle#select"
                class="px-4 py-3 font-medium text-sm transition-colors">
          Vinyl
        </button>
        <button type="button"
                data-media-type-toggle-target="button"
                data-now-playing-search-target="mediaTypeButton"
                data-media-type="CD"
                data-action="click->media-type-toggle#select"
                class="px-4 py-3 font-medium text-sm transition-colors">
          CD
        </button>
      </div>
      <button type="button"
              data-action="click->now-playing-search#fetchRandom mouseenter->now-playing-search#showRandomTooltip mouseleave->now-playing-search#hideRandomTooltip"
              class="px-4 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg whitespace-nowrap">
        Pick Random
      </button>

      <!-- Results dropdown -->
      <div data-now-playing-search-target="results"
           class="absolute z-10 left-0 right-16 mt-14 bg-white border border-gray-300 rounded-lg shadow-lg hidden">
      </div>
    </div>

    <%# <!-- Queue mode toggle -->
    <div class="flex items-center gap-2 mt-3">
      <input type="checkbox"
             id="queue-mode-toggle"
             data-now-playing-search-target="queueToggle"
             data-action="change->now-playing-search#toggleQueueMode"
             class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
      <label for="queue-mode-toggle" class="text-sm text-gray-600 cursor-pointer select-none">
        Add to <strong>Up Next</strong> instead of playing
      </label>
      <span data-now-playing-search-target="queueBadge"
            class="hidden px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700 rounded-full">
        Queue mode active
      </span>
    </div>
    %>
  </div> 
  <% end %>

  <!-- Now Playing / Up Next Tabs -->
  <% show_up_next = is_admin? && @playlist.any? %>
  <% show_now_playing = @now_playing.present? || show_up_next %>
  <% if show_now_playing %>
    <div class="mb-8" id="now-playing-section" data-controller="tabs">
      <!-- Plain heading when the queue is empty; tab bar when Up Next has items -->
      <h2 id="now-playing-heading" class="font-bold text-2xl mb-4 text-stone-700 <%= 'hidden' if show_up_next %>">Now Playing</h2>
      <div id="now-playing-tab-bar" class="mb-4 <%= 'hidden' unless show_up_next %>">
        <nav class="grid grid-cols-2 gap-1 rounded-lg bg-gray-200/70 p-1">
          <button type="button"
                  data-tabs-target="tab"
                  data-tab="now-playing"
                  data-action="tabs#select"
                  class="page-tab selected">
            Now Playing
          </button>
          <button type="button"
                  data-tabs-target="tab"
                  data-tab="up-next"
                  data-action="tabs#select"
                  class="page-tab">
            Up Next
          </button>
        </nav>
      </div>

      <!-- Now Playing panel: card at 75%, listening stats widget at 25% -->
      <div data-tabs-target="panel" data-tab="now-playing">
        <div class="flex flex-col lg:flex-row gap-4 items-stretch">
          <div class="lg:w-3/4">
            <% if @now_playing %>
              <%= render partial: "now_playing_card", locals: { media_item: @now_playing } %>
            <% else %>
              <div class="themed-card border shadow-lg p-6 h-full flex items-center justify-center text-gray-400">
                Nothing playing right now
              </div>
            <% end %>
          </div>
          <div class="lg:w-1/4">
            <div class="relative themed-card border shadow-lg p-4 h-full flex flex-col" data-controller="tabs">
              <h3 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-3 text-center">Listening Stats</h3>
              <nav class="grid grid-cols-2 gap-1 rounded-lg bg-gray-200/70 p-1 mb-3">
                <button type="button"
                        data-tabs-target="tab"
                        data-tab="last-days"
                        data-action="tabs#select"
                        class="widget-tab selected">
                  Last <%= @days_ago_play_history %> Days
                </button>
                <button type="button"
                        data-tabs-target="tab"
                        data-tab="lifetime"
                        data-action="tabs#select"
                        class="widget-tab">
                  Lifetime
                </button>
              </nav>
              <div class="flex-1 content-center">
                <% last_days_tooltip_lines = [] %>
                <% last_days_tooltip_lines << pluralize(@recently_played_vinyl_count, "LP") if @recently_played_vinyl_count.to_i > 0 %>
                <% last_days_tooltip_lines << pluralize(@recently_played_cd_count, "CD") if @recently_played_cd_count.to_i > 0 %>
                <% last_days_album_icon = album_stat_bubble(@total_recently_played, last_days_tooltip_lines) %>
                <% last_days_duration = capture do %>
                  <p class="<%= duration_font_size_class(@recently_played_in_seconds) %> font-bold text-stone-700 leading-tight"><%= duration_formatter(@recently_played_in_seconds) %></p>
                <% end %>
                <div data-tabs-target="panel" data-tab="last-days">
                  <div class="grid grid-cols-2 text-center">
                    <div class="p-2 flex items-center justify-center">
                      <%= is_admin? ? link_to(last_days_album_icon, play_sessions_path(days: @days_ago_play_history), class: "contents") : last_days_album_icon %>
                    </div>
                    <div class="p-2 flex items-center justify-center">
                      <%= is_admin? ? link_to(last_days_duration, play_sessions_path(days: @days_ago_play_history), class: "contents") : last_days_duration %>
                    </div>
                  </div>
                </div>
                <% lifetime_tooltip_lines = [] %>
                <% lifetime_tooltip_lines << pluralize(@lifetime_vinyl_count, "LP") if @lifetime_vinyl_count.to_i > 0 %>
                <% lifetime_tooltip_lines << pluralize(@lifetime_cd_count, "CD") if @lifetime_cd_count.to_i > 0 %>
                <% lifetime_album_icon = album_stat_bubble(@total_lifetime_played, lifetime_tooltip_lines) %>
                <% lifetime_duration = capture do %>
                  <p class="<%= duration_font_size_class(@lifetime_played_in_seconds) %> font-bold text-stone-700 leading-tight"><%= duration_formatter(@lifetime_played_in_seconds) %></p>
                <% end %>
                <div data-tabs-target="panel" data-tab="lifetime" class="hidden">
                  <div class="grid grid-cols-2 text-center">
                    <div class="p-2 flex items-center justify-center">
                      <%= is_admin? ? link_to(lifetime_album_icon, play_sessions_path, class: "contents") : lifetime_album_icon %>
                    </div>
                    <div class="p-2 flex items-center justify-center">
                      <%= is_admin? ? link_to(lifetime_duration, play_sessions_path, class: "contents") : lifetime_duration %>
                    </div>
                  </div>
                </div>
              </div>
              <% if @current_cartridge %>
                <div class="pt-3 border-t border-gray-200">
                  <p class="text-xs font-medium text-gray-600 truncate" title="<%= @current_cartridge.name %>"><%= @current_cartridge.name %></p>
                  <% used_hours = quarter_hours(@cartridge_hours_used) %>
                  <% if @current_cartridge.usage_limit %>
                    <% pct = [ used_hours / @current_cartridge.usage_limit.to_f * 100, 100 ].min %>
                    <% bar_color = pct >= 90 ? "bg-red-500" : pct >= 75 ? "bg-amber-500" : "bg-emerald-500" %>
                    <div class="mt-1.5 h-1.5 rounded-full bg-gray-200 overflow-hidden">
                      <div class="h-full rounded-full <%= bar_color %>" style="width: <%= pct.round(1) %>%"></div>
                    </div>
                    <% usage_text = "#{used_hours} of #{@current_cartridge.usage_limit} hrs · #{@current_cartridge.hours_remaining(@cartridge_hours_used)} remain" %>
                  <% else %>
                    <% usage_text = "#{used_hours} hrs used" %>
                  <% end %>
                  <% if is_admin? %>
                    <%= link_to usage_text, lp_cartridge_play_sessions_path(@current_cartridge), class: "text-xs text-gray-500 mt-1 hover:text-gray-700 hover:underline block" %>
                  <% else %>
                    <p class="text-xs text-gray-500 mt-1"><%= usage_text %></p>
                  <% end %>
                  <p class="text-xs text-gray-400 mt-0.5">Install Date: <%= @current_cartridge.installed_at.strftime("%b %-d, %Y") %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Up Next panel -->
      <% if is_admin? %>
        <div data-tabs-target="panel" data-tab="up-next" class="hidden">
          <%= render partial: "up_next" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Recently Played Section (older than 60 minutes) -->
  <% if @play_sessions&.any? %>
    <div class="mt-8">
      <div class="flex items-center gap-2 mb-4">
        <h2 class="font-bold text-2xl text-stone-700">Recently Played</h2>
        <% if is_admin? %>
          <button type="button"
                  data-controller="tweak-toggle"
                  data-action="click->tweak-toggle#toggle"
                  data-tweak-toggle-active-value="<%= params[:tweak].present? %>"
                  title="Toggle undo mode — show delete buttons on confirmed items"
                  class="text-gray-500 hover:text-gray-700 p-1 rounded transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
          </button>
        <% end %>
      </div>
      <% unless show_now_playing %>
        <%# Stats live in the Now Playing widget when that section is visible %>
        You've listened to <strong><%= @total_recently_played %></strong> albums over the past <strong><%= @days_ago_play_history %></strong> days for a total of <strong><%= duration_formatter(@recently_played_in_seconds) %></strong>.
        <% if @current_cartridge %>
          <br><span class="text-xs font-mono text-gray-500">Currently used <%= quarter_hours(@cartridge_hours_used) %> hours of <%= @current_cartridge.name %> last installed <%= @current_cartridge.installed_at.strftime("%b %-d, %Y") %><% if @current_cartridge.usage_limit %> (<%= @current_cartridge.hours_remaining(@cartridge_hours_used) %> hours remain)<% end %></span>
        <% end %>
      <% end %>
      <div data-controller="infinite-scroll" class="mt-4">
        <div data-infinite-scroll-target="container">
          <%= render partial: "recently_played_items" %>
        </div>

        <% if @has_more %>
          <div data-infinite-scroll-target="sentinel"
               data-url="<%= now_playing_path(page: 1) %>"
               class="h-8 mt-4">
          </div>
        <% end %>

        <div data-infinite-scroll-target="spinner" class="hidden py-8 flex justify-center">
          <svg class="w-6 h-6 text-gray-400 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </div>
      </div>
    </div>
  <% elsif @now_playing.nil? %>
    <div class="text-center py-12 bg-gray-50 rounded-lg">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
        <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z"/>
      </svg>
      <p class="text-gray-500 text-lg">No recently played albums</p>
      <p class="text-gray-400 mt-1">Search for an album above to start tracking your plays</p>
    </div>
  <% end %>
</div>
