<% content_for :title, "Users" %>

<div class="p-4">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">Users</h1>
    <%= link_to "Add User", new_user_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>

  <div class="bg-white shadow rounded-md divide-y divide-gray-200">
    <% if @users.any? %>
      <% @users.each do |user| %>
        <%= render user %>
      <% end %>
    <% else %>
      <p class="text-center py-10 text-gray-500">No users found.</p>
    <% end %>
  </div>
</div>
